---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';

// Fetch GitHub README at build time
let readmeHtml = '';
try {
	const res = await fetch(
		'https://raw.githubusercontent.com/alifiarahmah/alifiarahmah/main/README.md',
	);
	if (res.ok) {
		const raw = await res.text();
		readmeHtml = await marked.parse(raw);
	}
} catch (e) {
	console.warn('Could not fetch GitHub README:', e);
}

const socials = [
	{
		label: 'Email',
		href: 'mailto:alifiarahmah@outlook.com',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="36" height="36"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
	},
	{
		label: 'Instagram',
		href: 'https://instagram.com/hamharaifila',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="36" height="36"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
	},
	{
		label: 'GitHub',
		href: 'https://github.com/alifiarahmah',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="36" height="36"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
	},
	{
		label: 'LinkedIn',
		href: 'https://linkedin.com/in/alifiarahmah',
		svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="36" height="36"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
	},
];
---

<Layout>
	<!-- Hero Section -->
	<section
		class="flex items-center"
	>
		<img
			src="https://avatars.githubusercontent.com/u/28982967"
			alt="Alifia Rahmah"
			class="w-32 lg:w-48 rounded-full mb-6 shadow-md mr-5"
			width="192"
			height="192"
		/>
		<div>
  		<h1 class="text-3xl lg:text-4xl font-bold my-3">Alifia Rahmah</h1>

  		<p class="text-sm lg:text-md max-w-xl text-gray-700 italic dark:text-gray-200 my-2">
    		I build things, break things, and study why things do be like that. <br/>Aspiring security practicioner and researcher, have been building things since before the GPT era.
  		</p>

  		<!-- Social Links -->
  		<div class="flex items-center gap-5 my-6">
  			{
  				socials.map((s) => (
  					<a
  						href={s.href}
  						target="_blank"
  						rel="noopener noreferrer"
  						aria-label={s.label}
  						class="icon-btn text-gray-800 dark:text-gray-200"
  					>
  						<Fragment set:html={s.svg} />
  					</a>
  				))
  			}
  		</div>
		</div>
	</section>

	<!-- GitHub README Section -->
	{
		readmeHtml && (
			<section class="mt-16">
				<div
					class="prose prose-lg dark:prose-invert max-w-none
					prose-headings:font-bold prose-headings:my-4
					prose-a:text-blue-600 dark:prose-a:text-blue-400
					prose-img:rounded-md prose-img:inline-block prose-img:my-0
					prose-code:before:content-none prose-code:after:content-none
					prose-pre:bg-gray-900 prose-pre:text-gray-100"
				>
					<Fragment set:html={readmeHtml} />
				</div>
			</section>
		)
	}
</Layout>
