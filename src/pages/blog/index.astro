---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { fetchMediumPosts } from '../../lib/medium';

// Fetch both sources in parallel
const [localPosts, mediumPosts] = await Promise.all([
	getCollection('blog'),
	fetchMediumPosts(),
]);

// Unified post shape for the template
interface UnifiedPost {
	title: string;
	excerpt: string;
	date: string;
	href: string;
	isExternal: boolean;
	tags: string[];
}

const allPosts: UnifiedPost[] = [
	...localPosts.map((post) => ({
		title: post.data.title,
		excerpt: post.data.excerpt,
		date: post.data.date.toISOString().slice(0, 10),
		href: `/blog/${post.slug}`,
		isExternal: false,
		tags: post.data.tags,
	})),
	// Medium posts have no markdown tags, so they appear under "All" only
	...mediumPosts.map((post) => ({
		title: post.title,
		excerpt: post.excerpt,
		date: post.date,
		href: post.url,
		isExternal: true,
		tags: [] as string[],
	})),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Derive unique sorted tags and their counts at build time
const allTags = [...new Set(allPosts.flatMap((p) => p.tags))].sort();
const tagCounts: Record<string, number> = Object.fromEntries(
	allTags.map((tag) => [
		tag,
		allPosts.filter((p) => p.tags.includes(tag)).length,
	]),
);

const formatDate = (dateStr: string) =>
	new Date(dateStr).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});
---

<Layout title="Blog">
	<h1 class="text-3xl lg:text-4xl font-bold text-center mb-10">Blog</h1>

	{
		allPosts.length === 0 ? (
			<p class="text-center text-gray-500 dark:text-gray-400 text-lg py-16">
				No posts yet. Check back soon!
			</p>
		) : (
			<>
				<!-- Tag filter tabs -->
				<div
					id="filter-tabs"
					class="thin-scrollbar flex gap-2 mb-8 pb-2 whitespace-nowrap overflow-x-scroll"
					role="group"
					aria-label="Filter posts by tag"
				>
					<button class="filter-btn is-active" data-filter="All" aria-pressed="true">
						All
						<span class="ml-1.5 opacity-60 text-xs font-normal tabular-nums">
							({allPosts.length})
						</span>
					</button>

					{allTags.map((tag) => (
						<button class="filter-btn" data-filter={tag} aria-pressed="false">
							{tag}
							<span class="ml-1.5 opacity-60 text-xs font-normal tabular-nums">
								({tagCounts[tag]})
							</span>
						</button>
					))}
				</div>

				<!-- Post list -->
				<div
					id="post-list"
					class="flex flex-col divide-y divide-gray-200 dark:divide-gray-700"
				>
					{allPosts.map((post) => (
						<article
							class="py-4 transition-opacity duration-200"
							data-tags={JSON.stringify(post.tags)}
						>
							<!-- Title row -->
							<div class="flex flex-wrap items-start gap-3 mb-2">
								<a
									href={post.href}
									target={post.isExternal ? '_blank' : undefined}
									rel={post.isExternal ? 'noopener noreferrer' : undefined}
									class="group flex-1 min-w-0"
								>
									<h2 class="text-2xl font-bold my-0 leading-snug group-hover:underline underline-offset-4 inline">
										{post.title}
									</h2>
									{post.isExternal && (
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
											width="14"
											height="14"
											class="inline ml-1.5 mb-1 text-gray-400 dark:text-gray-500 shrink-0"
											aria-label="Opens in a new tab"
										>
											<path d="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" />
										</svg>
									)}
								</a>
							</div>

							<!-- Date -->
							<time
								datetime={post.date}
								class="text-sm text-gray-500 dark:text-gray-400 block mb-3"
							>
								{formatDate(post.date)}
							</time>

							<!-- Excerpt -->
							{post.excerpt && (
								<p class="text-base lg:text-lg text-gray-700 dark:text-gray-300 my-0 line-clamp-3">
									{post.excerpt}
								</p>
							)}

							<!-- Tags + read more -->
							<div class="flex items-center justify-between gap-2 flex-wrap mt-2">
								<div class="flex flex-wrap gap-2">
									{post.tags.map((tag) => (
										<button
											class="tag cursor-pointer hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-150"
											data-filter={tag}
											aria-label={`Filter by ${tag}`}
										>
											{tag}
										</button>
									))}
								</div>

								<a
									href={post.href}
									target={post.isExternal ? '_blank' : undefined}
									rel={post.isExternal ? 'noopener noreferrer' : undefined}
									class="inline-block font-bold text-sm hover:underline underline-offset-4"
								>
									{post.isExternal ? 'Read on Medium' : 'Read more'} &rarr;
								</a>
							</div>
						</article>
					))}
				</div>

				<!-- Pagination -->
				<nav
					id="pagination"
					aria-label="Pagination"
					class="hidden mt-10 flex-wrap items-center justify-center gap-2"
				>
					<button type="button" id="prev-page" class="pagination-btn" aria-label="Previous page">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="15 18 9 12 15 6"></polyline></svg>
					</button>
					<div id="page-numbers" class="flex items-center gap-1"></div>
					<button type="button" id="next-page" class="pagination-btn" aria-label="Next page">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="9 18 15 12 9 6"></polyline></svg>
					</button>
				</nav>

				<!-- Empty state -->
				<p
					id="no-results"
					class="hidden text-center text-gray-500 dark:text-gray-400 text-lg py-16"
				>
					No posts found for this tag.
				</p>
			</>
		)
	}
</Layout>

<script>
	const PAGE_SIZE = 10;

	const filterBtns = document.querySelectorAll<HTMLButtonElement>(
		'#filter-tabs .filter-btn, #post-list .tag[data-filter]',
	);
	const posts =
		document.querySelectorAll<HTMLElement>('#post-list article');
	const noResults = document.getElementById('no-results');
	const pagination = document.getElementById('pagination');
	const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
	const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null;
	const pageNumbers = document.getElementById('page-numbers');
	const postList = document.getElementById('post-list');

	let currentFilter = 'All';
	let currentPage = 1;

	// Read initial page from URL (?page=N) so refresh / shared links land on
	// the right page.
	const initialPage = parseInt(
		new URLSearchParams(window.location.search).get('page') ?? '1',
		10,
	);
	if (!Number.isNaN(initialPage) && initialPage >= 1) {
		currentPage = initialPage;
	}

	function getMatchingPosts(filter: string): HTMLElement[] {
		return Array.from(posts).filter((post) => {
			const tags: string[] = JSON.parse(post.dataset.tags ?? '[]');
			return filter === 'All' || tags.includes(filter);
		});
	}

	function applyState() {
		const matching = getMatchingPosts(currentFilter);
		const totalPages = Math.max(1, Math.ceil(matching.length / PAGE_SIZE));

		// Clamp current page into valid range (e.g. after switching filters)
		if (currentPage > totalPages) currentPage = totalPages;
		if (currentPage < 1) currentPage = 1;

		const start = (currentPage - 1) * PAGE_SIZE;
		const end = start + PAGE_SIZE;
		const visibleSet = new Set(matching.slice(start, end));

		posts.forEach((post) => {
			if (visibleSet.has(post)) {
				// Fade in
				post.style.opacity = '0';
				post.classList.remove('hidden');
				requestAnimationFrame(() =>
					requestAnimationFrame(() => {
						post.style.opacity = '1';
					}),
				);
			} else {
				// Fade out then hide
				post.style.opacity = '0';
				post.addEventListener(
					'transitionend',
					() => {
						if (post.style.opacity === '0') post.classList.add('hidden');
					},
					{ once: true },
				);
			}
		});

		noResults?.classList.toggle('hidden', matching.length > 0);
		renderPagination(totalPages);
		syncURL();
	}

	function renderPagination(totalPages: number) {
		if (!pagination || !pageNumbers || !prevBtn || !nextBtn) return;

		if (totalPages <= 1) {
			pagination.classList.add('hidden');
			pagination.classList.remove('flex');
			return;
		}
		pagination.classList.remove('hidden');
		pagination.classList.add('flex');

		prevBtn.disabled = currentPage === 1;
		nextBtn.disabled = currentPage === totalPages;

		pageNumbers.innerHTML = '';
		for (let i = 1; i <= totalPages; i++) {
			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'pagination-btn';
			btn.textContent = String(i);
			btn.setAttribute('aria-label', `Page ${i}`);
			if (i === currentPage) {
				btn.setAttribute('aria-current', 'page');
				btn.disabled = true;
			}
			btn.addEventListener('click', () => setPage(i));
			pageNumbers.appendChild(btn);
		}
	}

	function setActiveTab(selected: string) {
		document
			.querySelectorAll<HTMLButtonElement>('#filter-tabs .filter-btn')
			.forEach((btn) => {
				const isActive = btn.dataset.filter === selected;
				btn.classList.toggle('is-active', isActive);
				btn.setAttribute('aria-pressed', String(isActive));
			});
	}

	function setFilter(filter: string) {
		currentFilter = filter;
		currentPage = 1; // Filter changes always reset to the first page
		setActiveTab(filter);
		applyState();
	}

	function setPage(page: number) {
		if (page === currentPage) return;
		currentPage = page;
		applyState();
		// Scroll the list into view rather than jumping to the very top of the page
		postList?.scrollIntoView({ behavior: 'smooth', block: 'start' });
	}

	function syncURL() {
		const url = new URL(window.location.href);
		if (currentPage > 1) {
			url.searchParams.set('page', String(currentPage));
		} else {
			url.searchParams.delete('page');
		}
		// Avoid pushing duplicate history entries when the page doesn't change
		const current = new URL(window.location.href);
		if (current.searchParams.toString() === url.searchParams.toString()) return;
		history.pushState({ page: currentPage }, '', url);
	}

	// Filter handlers (top tabs + inline tag chips on each post)
	filterBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			const filter = btn.dataset.filter ?? 'All';
			setFilter(filter);
		});
	});

	// Prev / Next handlers
	prevBtn?.addEventListener('click', () => setPage(currentPage - 1));
	nextBtn?.addEventListener('click', () => setPage(currentPage + 1));

	// Browser back/forward — re-read page from URL and re-render
	window.addEventListener('popstate', () => {
		const page = parseInt(
			new URLSearchParams(window.location.search).get('page') ?? '1',
			10,
		);
		currentPage = Number.isNaN(page) || page < 1 ? 1 : page;
		applyState();
	});

	// Initial render
	applyState();
</script>
