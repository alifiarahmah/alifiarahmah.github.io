---
import Layout from '../layouts/Layout.astro';
import projects from '../data/projects.json';

interface Project {
	id: string;
	name: string;
	description: string;
	tags: string[];
	githubUrl: string | null;
	miscDownloadUrl: string | null;
	extUrl: string | null;
	createdAt: string;
}

const typedProjects = (projects as Project[]).sort((a, b) =>
	b.createdAt.localeCompare(a.createdAt)
);

// Derive unique sorted tags and their counts at build time
const allTags = [...new Set(typedProjects.flatMap((p) => p.tags))].sort();
const tagCounts: Record<string, number> = Object.fromEntries(
	allTags.map((tag) => [
		tag,
		typedProjects.filter((p) => p.tags.includes(tag)).length,
	]),
);

const isGitlab = (url: string) => url.slice(8, 14) === 'gitlab';
---

<Layout title="Projects">
	<h1 class="text-3xl lg:text-4xl font-bold text-center mb-10">Projects</h1>

	<!-- Filter tabs -->
	<div
		id="filter-tabs"
		class="flex gap-2 mb-8 overflow-x-auto pb-2 whitespace-nowrap"
		role="group"
		aria-label="Filter projects by tag"
	>
		<button class="filter-btn is-active" data-filter="All" aria-pressed="true">
			All
			<span class="ml-1.5 opacity-60 text-xs font-normal tabular-nums">
				({typedProjects.length})
			</span>
		</button>

		{
			allTags.map((tag) => (
				<button
					class="filter-btn"
					data-filter={tag}
					aria-pressed="false"
				>
					{tag}
					<span class="ml-1.5 opacity-60 text-xs font-normal tabular-nums">
						({tagCounts[tag]})
					</span>
				</button>
			))
		}
	</div>

	<!-- Project cards -->
	<div id="projects-list" class="flex flex-col gap-4">
		{
			typedProjects.map((project) => (
				<article
					class="border-[3px] border-black dark:border-white p-4 flex flex-col justify-between gap-4 transition-opacity duration-200"
					data-tags={JSON.stringify(project.tags)}
				>
					<!-- Top: name + description -->
					<div>
						<h3 class="text-xl font-bold my-2">{project.name}</h3>
						<p class="text-base lg:text-lg text-gray-700 dark:text-gray-300 my-1">
							{project.description}
						</p>
					</div>

					<!-- Bottom: tags + action buttons -->
					<div class="flex items-center justify-between gap-2 flex-wrap">
						<!-- Tags -->
						<div class="flex flex-wrap gap-2">
							{project.tags.map((tag) => (
								<button
									class="tag cursor-pointer hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-150"
									data-filter={tag}
									aria-label={`Filter by ${tag}`}
								>
									{tag}
								</button>
							))}
						</div>

						<!-- Action icon buttons -->
						<div class="flex items-center gap-1">
							{project.githubUrl && (
								<a
									href={project.githubUrl}
									target="_blank"
									rel="noopener noreferrer"
									aria-label={
										isGitlab(project.githubUrl) ? 'GitLab' : 'GitHub'
									}
									class="icon-btn text-gray-800 dark:text-gray-200"
								>
									{isGitlab(project.githubUrl) ? (
										/* GitLab icon */
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
											width="18"
											height="18"
										>
											<path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z" />
										</svg>
									) : (
										/* GitHub icon */
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
											width="18"
											height="18"
										>
											<path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
										</svg>
									)}
								</a>
							)}

							{project.miscDownloadUrl && (
								<a
									href={project.miscDownloadUrl}
									target="_blank"
									rel="noopener noreferrer"
									aria-label="Download"
									class="icon-btn text-gray-800 dark:text-gray-200"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="currentColor"
										width="16"
										height="16"
									>
										<path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
									</svg>
								</a>
							)}

							{project.extUrl && (
								<a
									href={project.extUrl}
									target="_blank"
									rel="noopener noreferrer"
									aria-label="Visit project"
									class="icon-btn text-gray-800 dark:text-gray-200"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="currentColor"
										width="16"
										height="16"
									>
										<path d="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" />
									</svg>
								</a>
							)}
						</div>
					</div>
				</article>
			))
		}
	</div>

	<!-- Empty state shown when no projects match the active filter -->
	<p
		id="no-results"
		class="hidden text-center text-gray-500 dark:text-gray-400 text-lg py-16"
	>
		No projects found for this tag.
	</p>
</Layout>

<style>
	#filter-tabs {
		/* Firefox - thin scrollbar */
		scrollbar-width: thin;
		scrollbar-color: rgba(0, 0, 0, 0.3) rgba(0, 0, 0, 0.05);
	}

	/* Dark mode - Firefox scrollbar */
	@media (prefers-color-scheme: dark) {
		#filter-tabs {
			scrollbar-color: rgba(255, 255, 255, 0.3) rgba(255, 255, 255, 0.05);
		}
	}

	/* Webkit (Chrome, Safari, Edge) - thin scrollbar */
	#filter-tabs::-webkit-scrollbar {
		height: 6px;
	}

	#filter-tabs::-webkit-scrollbar-track {
		background: rgba(0, 0, 0, 0.05);
		border-radius: 3px;
	}

	#filter-tabs::-webkit-scrollbar-thumb {
		background: rgba(0, 0, 0, 0.3);
		border-radius: 3px;
	}

	#filter-tabs::-webkit-scrollbar-thumb:hover {
		background: rgba(0, 0, 0, 0.5);
	}

	/* Dark mode - Webkit scrollbar */
	@media (prefers-color-scheme: dark) {
		#filter-tabs::-webkit-scrollbar-track {
			background: rgba(255, 255, 255, 0.05);
		}

		#filter-tabs::-webkit-scrollbar-thumb {
			background: rgba(255, 255, 255, 0.3);
		}

		#filter-tabs::-webkit-scrollbar-thumb:hover {
			background: rgba(255, 255, 255, 0.5);
		}
	}
</style>

<script>
	// ── Types ─────────────────────────────────────────────────────────
	const filterBtns = document.querySelectorAll<HTMLButtonElement>(
		'#filter-tabs .filter-btn, #projects-list .tag[data-filter]',
	);
	const cards =
		document.querySelectorAll<HTMLElement>('#projects-list article');
	const noResults = document.getElementById('no-results');

	// ── Core filter function ──────────────────────────────────────────
	function applyFilter(selected: string) {
		let visibleCount = 0;

		cards.forEach((card) => {
			const tags: string[] = JSON.parse(card.dataset.tags ?? '[]');
			const matches = selected === 'All' || tags.includes(selected);

			if (matches) {
				// Fade in
				card.style.opacity = '0';
				card.classList.remove('hidden');
				// Allow the browser to register the element before transitioning
				requestAnimationFrame(() => {
					requestAnimationFrame(() => {
						card.style.opacity = '1';
					});
				});
				visibleCount++;
			} else {
				// Fade out then hide
				card.style.opacity = '0';
				card.addEventListener(
					'transitionend',
					() => {
						if (card.style.opacity === '0') card.classList.add('hidden');
					},
					{ once: true },
				);
			}
		});

		// Toggle empty-state message
		noResults?.classList.toggle('hidden', visibleCount > 0);
	}

	// ── Active tab state ──────────────────────────────────────────────
	function setActiveTab(selectedFilter: string) {
		// Only update the top filter-tab buttons (not the inline tag chips)
		document
			.querySelectorAll<HTMLButtonElement>('#filter-tabs .filter-btn')
			.forEach((btn) => {
				const isActive = btn.dataset.filter === selectedFilter;
				btn.classList.toggle('is-active', isActive);
				btn.setAttribute('aria-pressed', String(isActive));
			});
	}

	// ── Event listeners ───────────────────────────────────────────────
	filterBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			const filter = btn.dataset.filter ?? 'All';
			setActiveTab(filter);
			applyFilter(filter);
		});
	});
</script>
